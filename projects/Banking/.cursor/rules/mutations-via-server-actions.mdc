# Mutation Pattern

- Implement write operations in Server Actions.
- Do not place mutation logic in API routes.
- Validate input and return a consistent `{ ok, error? }` shape.

## Example

```typescript
// BAD
export async function POST(req: Request) {
  // mutation logic here
}

// GOOD
"use server";

import { z } from "zod";

const InputSchema = z.object({ id: z.string().min(1) });

export async function updateThing(input: unknown): Promise<{ ok: boolean; error?: string }> {
  const parsed = InputSchema.safeParse(input);
  if (!parsed.success) return { ok: false, error: "Invalid input" };

  // mutation logic here
  return { ok: true };
}
```
