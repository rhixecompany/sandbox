{
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "actions/*": [
        "./src/actions/*"
      ],
      "app-config": [
        "./app-config.ts"
      ],
      "app/*": [
        "./src/app/*"
      ],
      "components/*": [
        "./src/components/*"
      ],
      "constants/*": [
        "./src/constants/*"
      ],
      "dal/*": [
        "./src/dal/*"
      ],
      "database/*": [
        "./src/database/*"
      ],
      "hooks/*": [
        "./src/hooks/*"
      ],
      "lib/*": [
        "./src/lib/*"
      ],
      "scripts": [
        "./scripts"
      ],
      "scripts/*": [
        "./scripts/*"
      ],
      "scripts/mcp-runner-lib": [
        "./scripts/mcp-runner-lib.ts"
      ],
      "scripts/plan-ensure": [
        "./scripts/plan-ensure.ts"
      ],
      "scripts/report-parser": [
        "./scripts/report-parser.ts"
      ],
      "scripts/ts/docs/generate-markdown-catalog": [
        "./scripts/ts/docs/generate-markdown-catalog.ts"
      ],
      "scripts/verify-rules": [
        "./scripts/verify-rules.ts"
      ],
      "stores/*": [
        "./src/stores/*"
      ],
      "tests/*": [
        "./tests/*"
      ],
      "types/*": [
        "./src/types/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2024",
    "types": [
      "bun",
      "node",
      "react",
      "react-dom",
      "vitest",
      "vitest/globals"
    ]
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "eslint.config.mts",
    "**/*.d.ts"
  ]
}
