{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "Next.js: Dev Server",
      "command": "bun run dev"
    },
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "Next.js: Build",
      "command": "bun run build"
    },
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "Next.js: Lint",
      "command": "bun run lint"
    },
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "TypeScript: Type Check",
      "command": "bun run type-check"
    },
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "Tests",
      "command": "bun run test"
    },
    {
      "name": "Bun: Current File",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "bun",
      "program": "${file}",
      "console": "integratedTerminal"
    }
  ]
}