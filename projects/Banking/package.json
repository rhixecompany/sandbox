{
  "name": "banking",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "type": "module",
  "scripts": {
    "prebuild": "bun run clean && bun run type-check",
    "build": "next build",
    "postbuild": "next-sitemap --config next-sitemap.config.ts",
    "build:analyze": "cross-env ANALYZE=true cross-env NODE_OPTIONS='--max-old-space-size=4096' ./node_modules/next/dist/bin/next build",
    "prebuild:debug": "bun run clean && bun run type-check",
    "build:debug": "cross-env NODE_OPTIONS='--max-old-space-size=4096' ./node_modules/next/dist/bin/next build --debug-prerender",
    "build:standalone": "next build",
    "cache": "bun pm cache",
    "cache:clean": "bun pm cache clean",
    "check-updates": "npm-check-updates --deep -i",
    "ci:checks:run": "bunx tsx scripts/ts/run-ci-checks.ts",
    "ci:helpers:fast-check": "bunx tsx bin/utils/ci-helpers/fast-check.ts",
    "ci:helpers:git-commit": "bunx tsx bin/utils/ci-helpers/git-commit-helper.ts",
    "ci:helpers:lint-fix": "bunx tsx bin/utils/ci-helpers/lint-fix-wrapper.ts",
    "ci:helpers:parse": "bunx tsx bin/utils/ci-helpers/parse-reports.ts",
    "ci:helpers:report": "bunx tsx bin/utils/ci-helpers/report-parser.ts",
    "ci:helpers:run": "bunx tsx bin/utils/ci-helpers/index.ts",
    "ci:helpers:seed-prep": "bunx tsx bin/utils/ci-helpers/seed-prep.ts",
    "ci:helpers:targeted-test": "bunx tsx bin/utils/ci-helpers/targeted-test-runner.ts",
    "clean": "rimraf .next out dist build .turbo coverage .react-email playwright-report test-results nul",
    "clean:all": "bun run clean && rimraf node_modules bun.lockb playwright-report test-results nul",
    "clean:cache": "rimraf .next/cache playwright-report test-results nul",
    "contributors:add": "all-contributors add",
    "contributors:check": "all-contributors check",
    "contributors:generate": "all-contributors generate",
    "db:check": "drizzle-kit check --config drizzle.config.ts",
    "db:drop": "drizzle-kit drop --config drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts || echo 'Drizzle not configured'",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:pull": "drizzle-kit introspect --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts --force",
    "db:reset": "bun run db:drop && bun run db:generate && bun run db:push",
    "db:seed": "cross-env PLAID_TOKEN_MODE=sandbox bunx tsx --env-file=.env.local scripts/seed/run.ts",
    "db:studio": "drizzle-kit studio",
    "deploy:htpasswd:generate": "bunx tsx scripts/ts/deploy/generate-htpasswd.ts",
    "deploy:run": "bunx tsx scripts/ts/entrypoints/deploy-cli.ts",
    "predev": "bun run clean",
    "dev": "next dev",
    "docker:build": "bunx tsx scripts/ts/docker/generate-env.ts",
    "docker:cleanup": "bunx tsx scripts/ts/cleanup/cleanup-docker.ts",
    "docker:deploy:check": "bunx tsx scripts/ts/docker/deploy-checklist.ts",
    "docker:env:generate": "bunx tsx scripts/ts/docker/generate-env.ts",
    "docker:quickstart": "bunx tsx scripts/ts/docker/docker-quickstart.ts",
    "docker:secrets:read": "bunx tsx scripts/ts/read-secrets.ts",
    "docs:cleanup": "bunx tsx scripts/ts/cleanup/cleanup-docs.ts",
    "docs:markdown:catalog": "bunx tsx scripts/ts/docs/generate-markdown-catalog.ts --write",
    "export:data": "bunx tsx scripts/export-data.ts",
    "format": "prettier --config .prettierrc.ts --write .",
    "format:check": "bun run format && prettier --config .prettierrc.ts --check .",
    "format:markdown:check": "markdownlint-cli2 --config .markdownlintrc.json '**/*.md' '#node_modules' '#.next' '#coverage' '#dist' '#build' '#out' '#tmp'",
    "format:markdown:fix": "markdownlint-cli2 --config .markdownlintrc.json --fix '**/*.md' '#node_modules' '#.next' '#coverage' '#dist' '#build' '#out' '#tmp'",
    "generate:action": "bunx tsx scripts/generate/action.ts",
    "generate:component": "bunx tsx scripts/generate/component.ts",
    "generate:dal": "bunx tsx scripts/generate/dal.ts",
    "generate:feature": "bunx tsx scripts/generate/feature.ts",
    "lint": "cross-env NODE_OPTIONS=--max-old-space-size=4096 eslint --config eslint.config.mts . --format=compact",
    "lint:fix": "cross-env NODE_OPTIONS=--max-old-space-size=4096 eslint --config eslint.config.mts . --fix --format=compact",
    "lint:fix:all": "cross-env NODE_OPTIONS=--max-old-space-size=4096 eslint --config eslint.config.mts . --fix --fix-type directive --fix-type problem --fix-type suggestion --fix-type layout --format=compact",
    "lint:strict": "cross-env NODE_OPTIONS=--max-old-space-size=4096 eslint --config eslint.config.mts . --max-warnings=0 --format=compact",
    "lint-staged": "lint-staged --config .lintstagedrc.ts",
    "opencode:plugins:disk:check": "bunx tsx scripts/ts/plugin-verify.ts --disk-only",
    "opencode:plugins:repair": "bunx tsx scripts/ts/plugin-repair.ts",
    "opencode:plugins:repair:apply": "bunx tsx scripts/ts/plugin-repair.ts --apply",
    "opencode:plugins:verify": "bunx tsx scripts/ts/plugin-verify.ts",
    "opencode-mcp": "bunx tsx scripts/ts/mcp-runner.ts",
    "opencode-mcp-list": "bun run opencode-mcp -- --list",
    "opencode-mcp-runner": "bunx tsx scripts/ts/mcp-runner.ts",
    "plan:ensure": "bunx tsx scripts/plan-ensure.ts",
    "prepare": "husky",
    "registry:build": "bun run registry:generate && bun run registry:export",
    "registry:export": "bunx tsx scripts/export-json.ts --pretty --output .opencode/registry.json",
    "registry:generate": "bunx tsx scripts/generate-readme.ts",
    "registry:generate:readme": "bunx tsx scripts/generate-readme.ts --all",
    "registry:validate": "bunx tsx scripts/validate.ts",
    "scripts:list": "node -e \"const s=JSON.parse(require('fs').readFileSync('package.json','utf8')).scripts; Object.entries(s).filter(([k])=>k.includes(':')).forEach(([k,v])=>console.log(k+' => '+v));\"",
    "start": "next start",
    "pretest": "bun run clean",
    "test": "bun run test:ui && bun run test:browser",
    "test:browser": "vitest --config=vitest.config.ts run .",
    "test:ui": "cross-env PLAYWRIGHT_PREPARE_DB=true playwright test --project=chromium",
    "test:ui:codegen": "playwright codegen --project=chromium",
    "test:ui:report": "playwright show-report --project=chromium",
    "type-check": "cross-env NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit --pretty",
    "type-check:watch": "tsc --noEmit --pretty --watch",
    "type-gen": "next typegen",
    "upstash": "bunx @upstash/qstash-cli dev",
    "validate": "bunx tsx scripts/validate.ts --all && bun run build && bun run lint:strict && bun run test",
    "validate:rules": "bunx tsx scripts/ts/entrypoints/run-verify-and-validate-cli.ts",
    "verify:rules": "bunx tsx scripts/verify-rules.ts",
    "verify:rules:ci": "bunx tsx scripts/verify-rules.ts --ci --output .opencode/reports/rules-report.json",
    "website:build": "bun run build && bun run website:data && bun run --prefix website build",
    "website:dev": "bun run website:data && bun run --prefix website dev",
    "website:preview": "bun run --prefix website preview"
  },
