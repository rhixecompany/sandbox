{
  "name": "comicbook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "."
  ],
  "scripts": {
    "___TIER_1_ESSENTIAL_WORKFLOW___": "_SCRIPTS_MARKER_",
    "___TIER_2_DATABASE_SEEDING___": "_SCRIPTS_MARKER_",
    "___TIER_3_HEALTH_MONITORING___": "_SCRIPTS_MARKER_",
    "___TIER_4_OPTIMIZATION_CODE_QUALITY___": "_SCRIPTS_MARKER_",
    "___TIER_5_CODE_GENERATION_UTILITIES___": "_SCRIPTS_MARKER_",
    "___UNIFIED_SCRIPTS___": "_SCRIPTS_MARKER_",
    "analyze:packages": "tsx src/scripts/uninstall-unused-packages.ts --dry-run",
    "analyze:project": "tsx --env-file=.env.local src/scripts/unified-performance-ops.ts --analysis --json",
    "prebuild": "pnpm clean && pnpm type-gen",
    "build": "cross-env NODE_OPTIONS='--max-old-space-size=4096' ./node_modules/next/dist/bin/next build",
    "postbuild": "pnpm next-sitemap --config next-sitemap.config.ts",
    "build:analyze": "cross-env ANALYZE=true cross-env NODE_OPTIONS='--max-old-space-size=4096' ./node_modules/next/dist/bin/next build",
    "build:debug": "cross-env NODE_OPTIONS='--max-old-space-size=4096' ./node_modules/next/dist/bin/next build --debug-prerender",
    "build:standalone": "cross-env NEXT_OUTPUT_MODE=standalone next build",
    "cache:clear": "tsx --env-file=.env.local src/scripts/clear-cache.ts",
    "cache:clear:dry": "tsx --env-file=.env.local src/scripts/clear-cache.ts --dry-run",
    "cache:stats": "tsx --env-file=.env.local src/scripts/cache-stats.ts",
    "cache:stats:json": "tsx --env-file=.env.local src/scripts/cache-stats.ts --json",
    "check-updates": "pnpm npm-check-updates --deep -i && pnpm update-browserslist-db --auto",
    "clean": "rimraf .next out dist build .turbo coverage .react-email",
    "clean:all": "pnpm clean && rimraf node_modules pnpm-lock.yaml",
    "clean:cache": "rimraf .next/cache",
    "cleanup:duplicates": "tsx --env-file=.env.local src/scripts/unified-dev-setup.ts --duplicates",
    "cleanup:duplicates:dry": "tsx --env-file=.env.local src/scripts/unified-dev-setup.ts --duplicates --dry-run",
    "cleanup:project": "tsx --env-file=.env.local src/scripts/unified-dev-setup.ts --cleanup",
    "cleanup:project:dry": "tsx --env-file=.env.local src/scripts/unified-dev-setup.ts --cleanup --dry-run",
    "cleanup:sh": "./cleanup.sh",
    "db": "tsx --env-file=.env.local src/scripts/unified-db-operations.ts",
    "db:check": "drizzle-kit check --config drizzle.config.ts",
    "db:drop": "drizzle-kit drop --config drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts || echo 'Drizzle not configured'",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:pull": "drizzle-kit introspect --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:reset": "pnpm db:drop && pnpm db:generate && pnpm db:push",
    "db:studio": "drizzle-kit studio",
    "predev": "pnpm clean && pnpm type-gen",
    "dev": "cross-env NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "dev:sh": "./dev.sh",
    "docs:all": "tsx src/scripts/master-setup.ts",
    "docs:generate": "tsx src/scripts/master-setup.ts --task=docs",
    "docs:prompts": "tsx src/scripts/master-setup.ts --task=prompts",
    "docs:readme": "tsx src/scripts/master-setup.ts --task=readme",
    "fix:duplicate-paths": "tsx --env-file=.env.local src/scripts/fix-duplicate-paths.ts",
    "fix:duplicate-paths:fix": "tsx --env-file=.env.local src/scripts/fix-duplicate-paths.ts --fix",
    "fix:line-endings": "tsx --env-file=.env.local src/scripts/fix-line-endings.ts --yes",
    "fix:line-endings:dry": "tsx --env-file=.env.local src/scripts/fix-line-endings.ts --dry-run",
    "format": "prettier --write .",
    "format:check": "pnpm format && prettier --check .",
