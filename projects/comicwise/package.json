    "seed:shares": "tsx --env-file=.env.local src/scripts/seed/run.ts shares",
    "seed:types": "tsx --env-file=.env.local src/scripts/seed/run.ts types",
    "seed:user-preferences": "tsx --env-file=.env.local src/scripts/seed/run.ts user-preferences",
    "seed:user-roles": "tsx --env-file=.env.local src/scripts/seed/run.ts user-roles",
    "seed:users": "tsx --env-file=.env.local src/scripts/seed/run.ts users",
