    "test:ui:codegen": "pnpm exec playwright codegen",
    "test:ui:example": "pnpm exec playwright test example",
    "test:ui:report": "pnpm exec playwright show-report",
    "triage": "tsx --env-file=.env.local src/scripts/triage-quality-gate.ts",
    "type-check": "tsc --noEmit --pretty",
    "type-check:watch": "tsc --noEmit --pretty --watch",
    "type-gen": "next typegen",
    "upstash": "pnpm dlx @upstash/qstash-cli dev",
    "validate": "pnpm format:check && pnpm type-check && pnpm lint:strict && pnpm imports:check && pnpm health:all && pnpm test",
    "validate:env": "tsx --env-file=.env.local src/scripts/unified-dev-setup.ts --validate-env --sync",
    "validate:env:dry": "tsx --env-file=.env.local src/scripts/unified-dev-setup.ts --validate-env --sync --dry-run",
    "vscode:extensions": "./install-vscode-extensions.sh"
