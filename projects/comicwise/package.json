    "health:all": "tsx --env-file=.env.local src/scripts/unified-project-health.ts --all",
    "health:check": "tsx --env-file=.env.local src/scripts/unified-project-health.ts --all",
    "health:check:json": "tsx --env-file=.env.local src/scripts/unified-project-health.ts --all --json",
    "health:check:verbose": "tsx --env-file=.env.local src/scripts/unified-project-health.ts --all --verbose",
    "health:db": "tsx --env-file=.env.local src/scripts/unified-project-health.ts --db",
    "health:db:json": "tsx --env-file=.env.local src/scripts/unified-project-health.ts --db --json",
    "health:db:verbose": "tsx --env-file=.env.local src/scripts/unified-project-health.ts --db --verbose",
