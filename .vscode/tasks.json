{
    "version": "2.0.0",
    "tasks": [
        {
            "command": "bun run format",
            "label": "Bash: Format",
            "type": "shell",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "options": {
                "cwd": "${workspaceFolder}/Bash"
            }
        },
        {
            "command": "bun run typecheck",
            "label": "Bash: Type Check",
            "type": "shell",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "options": {
                "cwd": "${workspaceFolder}/Bash"
            }
        },
        {
            "command": "bun run lint:strict",
            "label": "Bash: Lint",
            "type": "shell",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "options": {
                "cwd": "${workspaceFolder}/Bash"
            }
        },
        {
            "command": "bash tests/verify-dryrun.sh",
            "label": "Bash: Verify Dry Run",
            "type": "shell",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "options": {
                "cwd": "${workspaceFolder}/Bash"
            }
        },
        {
            "command": "bash test-all.sh",
            "label": "Bash: Test All",
            "type": "shell",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "options": {
                "cwd": "${workspaceFolder}/Bash"
            }
        },
        {
            "label": "PowerShell: Orchestrator Discover",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                ".\\orchestrator-unified.ps1 -Mode discover"
            ],
            "isBackground": true,
            "options": {
                "cwd": "${workspaceFolder}/Bash"
            }
        }
    ]
}
