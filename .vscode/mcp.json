{
	"servers": {
		"mcp-docker": {
			"command": "docker",
			"args": [
				"mcp",
				"gateway",
				"run",
				"--profile",
				"${input:hermes-profile}"
			],
			"env": {
				"LOCALAPPDATA": "${env:LOCALAPPDATA}",
				"ProgramData": "${env:ProgramData}",
				"ProgramFiles": "${env:ProgramFiles}"
			},
			"type": "stdio"
		},
		"mcp-filesystem": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"${workspaceFolder}"
			],
			"type": "stdio"
		},
		"mcp-github": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-github"
			],
			"env": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github-token}"
			},
			"type": "stdio"
		}
	},
	"inputs": [
		{
			"id": "hermes-profile",
			"type": "promptString",
			"description": "Hermes profile for Docker MCP gateway",
			"default": "default"
		},
		{
			"id": "github-token",
			"type": "promptString",
			"description": "GitHub Personal Access Token",
			"password": true
		}
	]
}
