{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Bun: Current File",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "bun",
      "program": "${file}",
      "preLaunchTask": "Bun: Build",
      "postDebugTask": "Bun: Test"
    },
    {
      "name": "Bun: Run All Tests",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "bun",
      "runtimeArgs": [
        "test"
      ],
      "console": "integratedTerminal",
      "preLaunchTask": "Bun: Build",
      "postDebugTask": "Bun: Test"
    },
    {
      "name": "Bun: Run All Tests (No Cache)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "bun",
      "args": [
        "test",
        "--no-cache"
      ],
      "console": "integratedTerminal",
      "preLaunchTask": "Bun: Build",
      "postDebugTask": "Bun: Test"
    },
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}"
    },
    {
      "name": "Node.js: Current File",
      "type": "node",
      "request": "launch",
      "program": "${file}"
    }
  ]
}
