{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Bun: Current File",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "bun",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "Bun: Run Tests",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "bun",
      "runtimeArgs": [
        "test"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Bun: Type Check",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "bun",
      "runtimeArgs": [
        "run",
        "typecheck"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Bun: Lint",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "bun",
      "runtimeArgs": [
        "run",
        "lint:strict"
      ],
      "console": "integratedTerminal"
    }
  ]
}
