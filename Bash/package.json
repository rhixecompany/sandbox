{
  "name": "opencode",
  "version": "1.0.0",
  "keywords": [],
  "license": "ISC",
  "type": "module",
  "scripts": {
    "clean:cache": "bunx tsx src/cache-clean.ts",
    "clean:cache:dry": "bunx tsx src/cache-clean.ts --all --dry-run",
    "clean:deps": "bunx tsx src/clean-dep.ts",
    "clean:deps:dry": "bunx tsx src/clean-dep.ts --dry-run",
    "commit:batches": "bunx tsx src/git-commit-batches.ts",
    "cross-ref": "bash Bash/scripts/phase-6-cross-ref.sh",
    "cross-ref:fix": "bash Bash/scripts/phase-6-cross-ref.sh --fix",
    "cross-ref:ps": "powershell.exe -NoProfile -File Bash/scripts/phase-6-cross-ref.ps1",
    "format": "prettier --config .prettierrc.ts --write .",
    "format:check": "bun run format && prettier --config .prettierrc.ts --check .",
    "format:markdown:check": "markdownlint-cli2 --config .markdownlintrc.json \"**/*.md\" \"#node_modules\" \"#.next\" \"#coverage\" \"#dist\" \"#build\" \"#out\" \"#tmp\"",
    "format:markdown:fix": "markdownlint-cli2 --config .markdownlintrc.json --fix \"**/*.md\" \"#node_modules\" \"#.next\" \"#coverage\" \"#dist\" \"#build\" \"#out\" \"#tmp\"",
    "lint": "cross-env NODE_OPTIONS=--max-old-space-size=4096 eslint --config eslint.config.mts . --format=compact",
    "lint:fix": "cross-env NODE_OPTIONS=--max-old-space-size=4096 eslint --config eslint.config.mts . --fix --format=compact",
    "lint:fix:all": "cross-env NODE_OPTIONS=--max-old-space-size=4096 eslint --config eslint.config.mts . --fix --fix-type directive --fix-type problem --fix-type suggestion --fix-type layout --format=compact",
    "lint:strict": "cross-env NODE_OPTIONS=--max-old-space-size=4096 eslint --config eslint.config.mts . --max-warnings=0 --format=compact",
    "lint-staged": "lint-staged --config .lintstagedrc.ts",
    "prepare": "husky",
    "typecheck": "tsc --noEmit --pretty",
    "upgrade": "bunx tsx src/upgrade.ts",
    "upgrade:debug": "bunx tsx src/upgrade.ts --debug",
    "verify-install": "bash Bash/scripts/phase-5-verify-install.sh"
  },
  "dependencies": {
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.8.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.1",
    "@types/bun": "latest",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "latest",
    "@typescript-eslint/parser": "^8.59.4",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "all-contributors-cli": "^6.26.1",
    "cross-env": "^10.1.0",
    "cspell": "^10.0.0",
    "dotenv": "^17.4.2",
    "dotenv-safe": "^9.1.0",
    "dts-gen": "^0.10.9",
    "eslint": "^10.4.0",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-compact": "^9.0.1",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-zod": "^3.12.1",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "globby": "^16.2.0",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "markdownlint": "^0.40.0",
    "markdownlint-cli": "^0.48.0",
    "markdownlint-cli2": "^0.22.1",
    "npm-check-updates": "^22.2.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-sort-json": "^4.2.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "pretty-quick": "^4.2.2",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "ts-stub": "^1.0.0",
    "tsx": "^4.22.3",
    "typescript": "latest",
    "typescript-eslint": "^8.59.4",
    "vaul": "^1.1.2",
    "vfile": "^6.0.3",
    "vfile-matter": "^5.0.1",
    "vitest": "^4.1.7"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=18"
  },
  "trustedDependencies": [
    "protobufjs",
    "esbuild",
    "sharp"
  ]
}
