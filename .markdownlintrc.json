{
	"config": {
		"default": true,
		"MD007": {
			"indent": 2
		},
		"MD013": false,
		"MD022": true,
		"MD024": {
			"siblings_only": true
		},
		"MD033": {
			"allowed_elements": [
				"br",
				"details",
				"kbd",
				"summary",
				"sub",
				"sup"
			]
		},
		"MD034": true,
		"MD041": true,
		"MD058": false,
		"MD060": false
	},
	"fix": true,
	"gitignore": true,
	"globs": [
		"**/*.md"
	],
	"ignores": [
		"node_modules",
		".next",
		".git",
		"build",
		"coverage",
		"dist",
		"out",
		"tmp"
	]
}
